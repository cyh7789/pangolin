# Sola Security MCP
# Get from: app.sola.security → Project → Settings → MCP → Generate OAuth
SOLA_CLIENT_ID=your-client-id-here
SOLA_CLIENT_SECRET=your-client-secret-here

# Slack Notification (optional)
# Webhook: Slack App → Incoming Webhooks → Add New
# Bot Token: Slack App → OAuth & Permissions → Bot User OAuth Token
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C...

# GitHub Token (for auto-fix PRs, optional)
# Or use: gh auth login
# GITHUB_TOKEN=ghp_...
